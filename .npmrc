; Zeabur / CI 環境網路偶爾抓 npm registry 中途斷線（ECONNRESET）。
; 把 fetch retry 從預設 2 拉到 5、間隔放寬、避免單一包失敗就整個 build 死。
fetch-retries=5
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
fetch-timeout=120000

; 偏好 offline cache、能用 cache 就用、不用每次都打 registry
prefer-offline=true

; package-lock.json 已 commit、依它走、不要 audit / fund 訊息浪費時間
audit=false
fund=false
loglevel=warn
