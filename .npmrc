; Zeabur / CI 環境網路偶爾抓 npm registry 中途斷線（ECONNRESET）。
; 把 retry 拉到 10 次、間隔放更寬、避免單一 package 失敗整個 build 死。
fetch-retries=10
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=180000
fetch-timeout=300000
maxsockets=4

; 偏好 offline cache、能用 cache 就用、不用每次都打 registry
prefer-offline=true

; package-lock.json 已 commit、依它走、不要 audit / fund 訊息浪費時間
audit=false
fund=false
loglevel=warn
