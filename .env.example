# ============================================================
# AI 島 v3 環境變數範本
# 複製成 .env.local 後逐項填值。已設的可從 admin/env 後台頁面看狀態。
# ============================================================

# ─── Supabase / 核心 ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=                       # postgresql://… 用來跑 migration
AI_KEY_SECRET=                         # AES-256 加密 user AI key 的 master secret
CRON_SECRET=                           # 外部 cron 觸發 KPI / 報表 / GA4 同步

# 後台路徑（亂數、避免被掃；兩個都填同一字串）
ADMIN_SLUG=
NEXT_PUBLIC_ADMIN_SLUG=

# 站台
NEXT_PUBLIC_SITE_URL=                  # https://your-domain.com（沒設 fallback vercel domain）
NEXT_PUBLIC_GA_ID=                     # G-XXXXX（GA4 measurement ID）
NEXT_PUBLIC_GTM_ID=                    # GTM-XXXXX（選填）
NEXT_PUBLIC_CONTENT_SOURCE=            # db / file (預設 db、章節從 DB 載)
NEXT_PUBLIC_SENTRY_DSN=                # 前端 Sentry（選填）

ADMIN_EMAILS=                          # 逗號分隔 admin email、登入後自動升 admin role

# ─── AI Provider Keys（system fallback、user 也可用 BYOK） ───
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=

# ─── Email ───
RESEND_API_KEY=                        # Resend.com email service
EMAIL_FROM=                            # noreply@your-domain.com（需 DKIM 設好）

# ─── LINE bot / admin 通知 ───
ADMIN_LINE_CHANNEL_TOKEN=              # Messaging API channel access token
ADMIN_LINE_CHANNEL_SECRET=             # Messaging API channel secret
ADMIN_LINE_USER_ID=                    # 主 admin LINE userId（單 admin 用）

# Multi-admin JSON（取代上面 USER_ID，例如多人共用通知）
# [{"id":"Uxxx","name":"luffy","role":"董事長"},{"id":"Uyyy","name":"nami","role":"客服主管"}]
ADMIN_LINE_USERS=
ADMIN_LINE_USER_LABEL=                 # 顯示名（單 admin 用、optional）
ADMIN_LINE_USER_ROLE=                  # 角色（owner / admin / 董事長…）

ADMIN_LINE_NOTIFY_TOKEN=               # 舊 LINE Notify (2025-03 退役，能用就用 Messaging API)
RICH_MENU_IMAGE_URL=                   # Rich Menu PNG 圖網址 (2500×1686)
ADMIN_LINE_BOT_BASIC_ID=               # admin bot 的 @basicId（紀錄用、admin 自己加好友、不必 NEXT_PUBLIC）

# ─── USER bot（一般使用者加好友、推學習通知；跟 admin bot 分兩個 LINE channel）───
# 在 LINE Developer Console 建第二個 Messaging API channel 給用戶端用
# Webhook URL = https://<site>/api/line-webhook-user
USER_LINE_CHANNEL_TOKEN=
USER_LINE_CHANNEL_SECRET=
NEXT_PUBLIC_USER_LINE_BOT_BASIC_ID=    # user bot 的 @basicId（給 /settings 加好友 deeplink 用、NEXT_PUBLIC 才能在 client 讀）

# ─── 使用者端 LINE Login（OAuth 登入、用 user bot 同一個 channel 也行、看設定）───
LINE_CHANNEL_ID=
NEXT_PUBLIC_LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# ─── Telegram / Discord 通知（補強通道、選填）───
ADMIN_TELEGRAM_BOT_TOKEN=              # Telegram bot token（@BotFather 拿）
ADMIN_TELEGRAM_CHAT_ID=                # 自己對 bot 發 /start、用 getUpdates 拿 chat_id
ADMIN_DISCORD_WEBHOOK_URL=             # Discord channel webhook URL
ADMIN_NOTIFY_ALL=                      # "1" = 全通道推、預設只推 LINE

# ─── Geo / IP 反查 ───1
IPINFO_TOKEN=                          # ipinfo.io token（IP→城市/ISP）
GOOGLE_MAPS_API_KEY=                   # GPS 反查台灣縣市（選填、沒設 fallback OSM Nominatim）

# ─── GA4 報表 API ───
GA4_PROPERTY_ID=                       # GA4 property numeric ID（不是 G-XXXXX）
GA4_SA_CREDENTIALS=                    # Service Account JSON（原文或 base64）

# ─── 第三方 ───
LEETCODE_STATS_URL=                    # 自架 leetcode-stats-api fork URL（選填、沒設用公開）

# ─── Cloudflare R2 圖片 / 媒體儲存 ───
# 個人大頭貼 / 部落格圖 / 論壇 / 留言 / AI 對話附圖都存這
# 設定步驟：
#   1. Cloudflare → R2 → Create bucket（記下 bucket name）
#   2. 該 bucket Settings → Public access → 開啟、拿到 pub-xxx.r2.dev URL
#   3. R2 → Manage API tokens → Create API token（讀寫該 bucket 權限）
#   4. CORS 設 https://aiisland.tw + http://localhost:3000
R2_ACCOUNT_ID=                         # Cloudflare account ID (32 字 hex)
R2_ACCESS_KEY_ID=                      # API token access key
R2_SECRET_ACCESS_KEY=                  # API token secret
R2_BUCKET_NAME=                        # bucket 名（自己取、例 ai-island-uploads）
R2_URL=https://pub-9216b1aca8cd47a08e50eff656429d96.r2.dev